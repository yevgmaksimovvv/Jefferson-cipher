# Core
PROJECT_NAME=Jefferson Cipher Service
SECRET_KEY=change-me-in-local-dev-secret-key-32-bytes-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jefferson
# Основной URL для Docker Compose (сервис postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/jefferson
# Helper для команд с хоста (не используется автоматически внутри контейнера)
DATABASE_URL_LOCAL=postgresql+psycopg://postgres:postgres@localhost:5432/jefferson

# Redis / rate limiting
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE=auto
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=10
RATE_LIMIT_CIPHER_PER_MINUTE=10
RATE_LIMIT_MUTATION_PER_MINUTE=10

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost,https://localhost:8443

# Nginx / local HTTPS
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
NGINX_CERT_PATH=/etc/nginx/certs/localhost.crt
NGINX_KEY_PATH=/etc/nginx/certs/localhost.key
# Host-директория (mount в nginx). Поместите сюда fullchain.pem и privkey.pem для кастомных сертификатов
NGINX_HOST_CERT_DIR=./nginx/certs
NGINX_GENERATE_SELF_SIGNED=true

# Trusted proxy
# TRUSTED_PROXY_IPS="*" допустим только для local/dev
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IPS=*

# HSTS
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000
