POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jefferson
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/jefferson
DATABASE_URL_LOCAL=postgresql+psycopg://postgres:postgres@localhost:5432/jefferson
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jefferson
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-local-dev-secret-key-32-bytes-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_STORAGE=auto
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=10
RATE_LIMIT_CIPHER_PER_MINUTE=10
RATE_LIMIT_MUTATION_PER_MINUTE=10
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost,https://localhost:8443
